{
  "name": "BloomIsland",
  "tree": {
    "$className": "DataModel",
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src/server"
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$path": "src/client"
      }
    },
    "StarterGui": {
      "$className": "StarterGui",
      "$path": "src/starter"
    },
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Shared": {
        "$path": "src/shared"
      },
      "Remotes": {
        "$className": "Folder"
      }
    },
    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "FilteringEnabled": true
      },
      "Garden": {
        "$className": "Folder"
      },
      "Weather": {
        "$className": "Folder"
      }
    },
    "ServerStorage": {
      "$className": "ServerStorage",
      "Assets": {
        "$className": "Folder"
      }
    },
    "SoundService": {
      "$className": "SoundService",
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
